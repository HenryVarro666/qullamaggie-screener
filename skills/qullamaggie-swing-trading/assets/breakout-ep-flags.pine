//@version=6
// Qullamaggie Breakout / EP flags — TradingView helper for the "no Deepvue" workflow.
// Apply on the DAILY timeframe. It computes ADR%(20), 1M/3M/6M performance, gap% and
// relative volume, marks bars that meet the Breakout or EP screen, and exposes alerts so
// you can watch a whole watchlist semi-automatically (TradingView Pine can't scan the whole
// market — set an alert per symbol instead). Numeric screen only; confirm Stage 2 + the base
// on the chart yourself. Not financial advice.
indicator("Qullamaggie Breakout / EP Flags", overlay=true)

adrMin  = input.float(3.0,   "ADR% min (20d)")
p6Min   = input.float(20.0,  "Breakout: 6M perf% min")
p3Min   = input.float(5.0,   "Breakout: 3M perf% min")
p1Min   = input.float(-20.0, "Breakout: 1M perf% min")
gapMin  = input.float(10.0,  "EP: gap% min")
rvMin   = input.float(1.5,   "EP: rel-vol min")
p6CapEP = input.float(100.0, "EP: 6M perf% cap (not already run)")

adr   = 100.0 * (ta.sma(high / low, 20) - 1.0)
perf6 = 100.0 * (close / close[126] - 1.0)
perf3 = 100.0 * (close / close[63]  - 1.0)
perf1 = 100.0 * (close / close[21]  - 1.0)
gap   = 100.0 * (open  / close[1]   - 1.0)
relv  = volume / ta.sma(volume, 20)

isBreakout = close >= 1 and adr >= adrMin and perf6 >= p6Min and perf3 >= p3Min and perf1 >= p1Min
isEP       = close >= 1 and gap >= gapMin and relv >= rvMin and perf6 <= p6CapEP

plotshape(isBreakout, title="Breakout", style=shape.triangleup, location=location.belowbar, color=color.lime,   size=size.small, text="BO")
plotshape(isEP,       title="EP",       style=shape.labelup,    location=location.belowbar, color=color.orange, size=size.small, text="EP")

alertcondition(isBreakout, "Breakout setup", "Qullamaggie Breakout 条件满足")
alertcondition(isEP,       "EP setup",       "Qullamaggie EP 条件满足")

var table t = table.new(position.top_right, 2, 6, frame_color=color.gray, frame_width=1)
if barstate.islast
    table.cell(t, 0, 0, "ADR% 20d", text_color=color.white)
    table.cell(t, 1, 0, str.tostring(adr, "#.#") + "%", text_color = adr >= adrMin ? color.green : color.red)
    table.cell(t, 0, 1, "Perf 6M", text_color=color.white)
    table.cell(t, 1, 1, str.tostring(perf6, "#") + "%", text_color = perf6 >= p6Min ? color.green : color.red)
    table.cell(t, 0, 2, "Perf 3M", text_color=color.white)
    table.cell(t, 1, 2, str.tostring(perf3, "#") + "%", text_color=color.white)
    table.cell(t, 0, 3, "Perf 1M", text_color=color.white)
    table.cell(t, 1, 3, str.tostring(perf1, "#") + "%", text_color=color.white)
    table.cell(t, 0, 4, "Gap / RelVol", text_color=color.white)
    table.cell(t, 1, 4, str.tostring(gap, "#.#") + "% / " + str.tostring(relv, "#.#") + "x", text_color=color.white)
    table.cell(t, 0, 5, "Setup", text_color=color.white)
    setupTxt = (isBreakout ? "✓BO " : "") + (isEP ? "⚡EP" : "") + (not isBreakout and not isEP ? "—" : "")
    table.cell(t, 1, 5, setupTxt, text_color=color.white, bgcolor = isBreakout or isEP ? color.new(color.green, 0) : color.new(color.gray, 40))
